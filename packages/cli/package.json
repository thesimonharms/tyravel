{
  "name": "@tyravel/cli",
  "version": "0.14.0",
  "description": "The Tyravel command-line interface",
  "type": "module",
  "bin": {
    "tyravel": "./dist/bin/tyravel.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tyravel/crypto": "0.14.0",
    "@tyravel/support": "0.14.0",
    "@tyravel/auth-oauth": "0.14.0",
    "@tyravel/config": "0.14.0",
    "@tyravel/locale": "0.14.0",
    "@tyravel/core": "0.14.0",
    "@tyravel/database": "0.14.0",
    "@tyravel/mcp": "0.14.0",
    "@tyravel/vector": "0.14.0",
    "@tyravel/debug": "0.14.0",
    "@tyravel/queue": "0.14.0",
    "@tyravel/views": "0.14.0",
    "@tyravel/repl": "0.14.0"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=26"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thesimonharms/tyravel.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  }
}
