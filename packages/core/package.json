{
  "name": "@tyravel/core",
  "version": "1.0.3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tyravel/auth": "1.0.3",
    "@tyravel/broadcasting": "1.0.3",
    "@tyravel/cache": "1.0.3",
    "@tyravel/config": "1.0.3",
    "@tyravel/crypto": "1.0.3",
    "@tyravel/database": "1.0.3",
    "@tyravel/events": "1.0.3",
    "@tyravel/container": "1.0.3",
    "@tyravel/http": "1.0.3",
    "@tyravel/locale": "1.0.3",
    "@tyravel/log": "1.0.3",
    "@tyravel/mail": "1.0.3",
    "@tyravel/notifications": "1.0.3",
    "@tyravel/queue": "1.0.3",
    "@tyravel/redis": "1.0.3",
    "@tyravel/storage": "1.0.3",
    "@tyravel/validation": "1.0.3",
    "@tyravel/views": "1.0.3"
  },
  "files": [
    "dist"
  ],
  "description": "Tyravel application kernel, providers, and facades",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thesimonharms/tyravel.git",
    "directory": "packages/core"
  },
