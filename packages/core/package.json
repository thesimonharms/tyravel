{
  "name": "@tyravel/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tyravel/auth": "0.1.0",
    "@tyravel/cache": "0.1.0",
    "@tyravel/config": "0.1.0",
    "@tyravel/database": "0.1.0",
    "@tyravel/events": "0.1.0",
    "@tyravel/container": "0.1.0",
    "@tyravel/http": "0.1.0",
    "@tyravel/mail": "0.1.0",
    "@tyravel/notifications": "0.1.0",
    "@tyravel/queue": "0.1.0",
    "@tyravel/validation": "0.1.0",
    "@tyravel/views": "0.1.0"
  },
  "files": [
    "dist"
  ],
  "description": "Tyravel application kernel, providers, and facades",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thesimonharms/tyravel.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  }
