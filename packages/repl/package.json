{
  "name": "@tyravel/repl",
  "version": "1.0.3",
  "description": "Interactive Tyravel REPL (tyravel shell)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thesimonharms/tyravel.git",
    "directory": "packages/repl"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=26"
  },
  "dependencies": {
    "@tyravel/config": "1.0.3",
    "@tyravel/core": "1.0.3",
    "@tyravel/support": "1.0.3"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
