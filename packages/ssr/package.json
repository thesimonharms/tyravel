{
  "name": "@tyravel/ssr",
  "version": "0.14.0",
  "description": "Client-side hydration runtime for Tyravel SSR islands",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thesimonharms/tyravel.git",
    "directory": "packages/ssr"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=26"
  },
  "devDependencies": {
    "happy-dom": "^20.0.10",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
