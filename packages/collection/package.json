{
  "name": "@pondoknusa/collection",
  "version": "2.0.0",
  "description": "Fluent, typed collection pipeline for Pondoknusa",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pondoknusa/pondoknusa.git",
    "directory": "packages/collection"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=26"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
