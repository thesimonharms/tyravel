{
  "name": "pondoknusa",
  "displayName": "Pondoknusa",
  "description": "Syntax highlighting and snippets for Pondoknusa .tyr templates",
  "version": "0.1.0",
  "publisher": "pondoknusa",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Snippets"],
  "contributes": {
    "languages": [
      {
        "id": "tyr",
        "aliases": ["Pondoknusa", "tyr"],
        "extensions": [".tyr"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tyr",
        "scopeName": "source.tyr",
        "path": "./syntaxes/tyr.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tyr",
        "path": "./snippets/pondoknusa.code-snippets"
      }
    ]
  },
  "scripts": {
    "package": "vsce package"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pondoknusa/pondoknusa.git",
    "directory": "tools/vscode-pondoknusa"
  }
}